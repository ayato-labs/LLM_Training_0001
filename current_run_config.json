{
    "model_params": {
        "n_params": 150000000,
        "hidden_size": 888,
        "num_hidden_layers": 14,
        "num_attention_heads": 12,
        "num_key_value_heads": 3
    },
    "hpo": {
        "n_params": 150000000,
        "n_tokens": 30000000,
        "seq_len": 512,
        "max_lr_2d": 0.01,
        "max_lr_1d": 0.002979,
        "min_lr": 1e-05,
        "batch_size_tokens": 10786,
        "batch_size_seqs": 21,
        "stable_lr_ratio": 0.55,
        "stable_lr_2d": 0.0055,
        "warmup_ratio": 0.03
    },
    "data_path": "data/dataset.jsonl",
    "tokenizer_path": "data/tokenizer.json",
    "max_steps": -1,
    "num_epochs": 3,
    "seed": 42,
    "_hydra_cfg": {
        "hardware": {
            "vram_limit_gb": 4.0,
            "precision": "bf16",
            "precision_bytes": 2
        },
        "data": {
            "db_path": "../Novel_Data_Collection/novels.db",
            "corpus_path": "data/corpus.jsonl",
            "dataset_path": "data/dataset.jsonl",
            "tokenizer_path": "data/tokenizer.json",
            "preprocessing": {
                "chunk_size": 1024,
                "overlap": 100
            }
        },
        "model": {
            "arch": "llama",
            "target_params": 150000000,
            "proxy_min_params": 30000000,
            "llama": {
                "hidden_size": 768,
                "num_hidden_layers": 12,
                "num_attention_heads": 12,
                "num_key_value_heads": 3,
                "intermediate_size": 3072,
                "rope_theta": 10000.0
            }
        },
        "tokenizer": {
            "vocab_size": 64000,
            "special_tokens": [
                "[UNK]",
                "[CLS]",
                "[SEP]",
                "[PAD]",
                "[MASK]",
                "<|start_of_metadata|>",
                "<|end_of_metadata|>",
                "<|start_of_story|>",
                "<|end_of_story|>"
            ]
        },
        "training": {
            "seq_len": 512,
            "max_steps": -1,
            "num_epochs": 3,
            "target_tokens": 30000000,
            "chinchilla_ratio": 100,
            "hpo": {
                "min_lr": 1e-05,
                "warmup_ratio": 0.03,
                "stable_lr_ratio": 0.55
            },
            "optimizer": {
                "muon_lr_ratio": 1.0,
                "adamw_lr_ratio": 0.298,
                "adamw_betas": [
                    0.9,
                    0.95
                ],
                "weight_decay": 0.01
            }
        },
        "seed": 42,
        "mlflow": {
            "tracking_uri": "file:./mlruns",
            "experiment_name": "LLM_Training"
        },
        "checkpoint": {
            "save_strategy": "steps",
            "save_steps": 1000,
            "save_total_limit": 3
        },
        "logging": {
            "report_to": [
                "tensorboard"
            ],
            "logging_steps": 10
        },
        "run_preprocessing": false
    }
}