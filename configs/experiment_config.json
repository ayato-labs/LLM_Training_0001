{
  "seed": 42,
  "data": {
    "train_data_path": "data/train_dataset.jsonl",
    "val_data_path": "data/val_dataset.jsonl",
    "tokenizer_path": "data/tokenizer.json",
    "dataset_path": "data/dataset.jsonl",
    "db_path": "../Novel_Data_Collection/novels.db"
  },
  "model": {
    "hidden_size": 768,
    "num_hidden_layers": 12,
    "num_attention_heads": 12,
    "intermediate_size": 3072,
    "max_position_embeddings": 2048,
    "vocab_size": 64000,
    "n_params": 150000000
  },
  "training": {
    "seq_len": 1024,
    "batch_size_seqs": 16,
    "max_lr_2d": 3e-4,
    "max_lr_1d": 3e-3,
    "warmup_ratio": 0.03,
    "num_epochs": 3,
    "max_steps": -1,
    "save_steps": 1000,
    "eval_steps": 1000,
    "logging_steps": 10
  },
  "hardware": {
    "vram_limit_gb": 4.0,
    "precision": "bf16"
  }
}